#!/usr/bin/env bash
set -euo pipefail

DEBUG=false
if [[ "${1:-}" == "--debug" ]]; then
  DEBUG=true
  shift
fi

debug() {
  if $DEBUG; then
    echo "[debug] $*" >&2
  fi
}

CONFIG_FILE=".envtree.json"

# Find repo root from current directory
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || {
  echo "Error: not inside a git repository."
  exit 1
}

usage() {
  echo "Usage: envtree [--debug] <init|pull|push>"
  echo ""
  echo "  init          Create a $CONFIG_FILE config file for this repo"
  echo "  pull [<dir>]  Copy .env files from source into this worktree"
  echo "  push [<dir>]  Copy .env files from this worktree into target"
  echo ""
  echo "  --debug       Show detailed resolution and copy steps"
  echo ""
  echo "Source priority: <dir> arg > \"source\" in $CONFIG_FILE > main git worktree"
  exit 1
}

# Resolve env files from config globs
resolve_files() {
  local root="$1"
  local config="${REPO_ROOT}/${CONFIG_FILE}"

  if [ ! -f "$config" ]; then
    echo "Error: $CONFIG_FILE not found in repo root."
    echo "Run 'envtree init' to create one."
    exit 1
  fi

  local globs
  globs="$(sed -n '/\"files\"/,/\]/{ s/^ *"\([^"]*\)".*/\1/p; }' "$config" | grep -v '^files$')"
  debug "config globs: $(echo "$globs" | tr '\n' ', ')"

  local files=()
  while IFS= read -r glob; do
    debug "resolving glob '$glob' in $root"
    if [[ "$glob" != *'**'* ]]; then
      # No recursive wildcard — use fast bash globbing
      local matches
      matches=( $(cd "$root" && compgen -G "./$glob" 2>/dev/null) ) || true
      for match in "${matches[@]}"; do
        files+=("${match#./}")
      done
    else
      # Recursive glob — use find with -prune for speed
      while IFS= read -r -d '' match; do
        files+=("${match#./}")
      done < <(cd "$root" && find . \
        \( -name node_modules -o -name .git -o -name .next -o -name dist -o -name .cache -o -name vendor \) -prune \
        -o -path "./$glob" -print0 2>/dev/null)
    fi
  done <<< "$globs"

  debug "resolved ${#files[@]} file(s): ${files[*]}"
  printf '%s\n' "${files[@]}"
}

get_config_source() {
  local config="${REPO_ROOT}/${CONFIG_FILE}"
  if [ -f "$config" ]; then
    local raw
    raw="$(sed -n 's/^ *"source" *: *"\(.*\)".*/\1/p' "$config" | head -1)"
    if [ -n "$raw" ]; then
      # Expand ~ to home directory
      local expanded="${raw/#\~/$HOME}"
      debug "config source: '$raw' -> '$expanded'"
      if [ -d "$expanded" ]; then
        echo "$expanded"
      else
        echo "Error: source directory '$raw' from $CONFIG_FILE not found." >&2
        exit 1
      fi
    fi
  fi
}

get_main_worktree() {
  local main
  main="$(git worktree list --porcelain | grep '^worktree ' | head -1 | sed 's/^worktree //')"
  debug "main worktree: '$main', current repo: '$REPO_ROOT'"

  if [ -z "$main" ]; then
    echo "Error: could not detect main worktree." >&2
    exit 1
  fi

  if [ "$main" = "$REPO_ROOT" ]; then
    echo "Error: you're already in the main worktree. Nothing to sync." >&2
    exit 1
  fi

  echo "$main"
}

cmd_init() {
  local config="${REPO_ROOT}/${CONFIG_FILE}"

  if [ -f "$config" ]; then
    echo "$CONFIG_FILE already exists:"
    cat "$config"
    echo ""
    printf "Overwrite? [y/N] "
    read -r answer
    if [[ ! "$answer" =~ ^[Yy]$ ]]; then
      echo "Aborted."
      exit 0
    fi
  fi

  echo "Enter .env file glob patterns (one per line, empty line to finish):"
  echo "Examples: apps/api/.env.local, **/.env, apps/*/.env.local"
  echo ""

  local globs=()
  while true; do
    printf "> "
    read -r glob
    [ -z "$glob" ] && break
    globs+=("$glob")
  done

  if [ ${#globs[@]} -eq 0 ]; then
    echo "No patterns entered. Aborted."
    exit 1
  fi

  printf '{\n  "files": [\n' > "$config"
  local i=0
  for g in "${globs[@]}"; do
    [ $i -gt 0 ] && printf ',\n' >> "$config"
    printf '    "%s"' "$g" >> "$config"
    i=$((i + 1))
  done
  printf '\n  ]\n}\n' >> "$config"

  echo ""
  echo "Created $CONFIG_FILE:"
  cat "$config"
}

cmd_pull() {
  local source label
  if [ -n "${1:-}" ]; then
    source="$(cd "$1" && pwd)" || { echo "Error: directory '$1' not found." >&2; exit 1; }
    label="$source"
  else
    source="$(get_config_source)"
    if [ -n "$source" ]; then
      label="$source"
    else
      source="$(get_main_worktree)"
      label="main worktree"
    fi
  fi

  debug "pull source: '$source' ($label)"

  local files
  files="$(resolve_files "$source")"

  if [ -z "$files" ]; then
    echo "No .env files matched in $label."
    exit 1
  fi

  local count=0
  while IFS= read -r rel; do
    src="${source}/${rel}"
    dest="${REPO_ROOT}/${rel}"
    mkdir -p "$(dirname "$dest")"
    debug "cp $src -> $dest"
    cp "$src" "$dest"
    echo "  pulled: $rel"
    count=$((count + 1))
  done <<< "$files"

  echo "Pulled $count env file(s) from $label"
}

cmd_push() {
  local target label
  if [ -n "${1:-}" ]; then
    target="$(cd "$1" && pwd)" || { echo "Error: directory '$1' not found." >&2; exit 1; }
    label="$target"
  else
    target="$(get_config_source)"
    if [ -n "$target" ]; then
      label="$target"
    else
      target="$(get_main_worktree)"
      label="main worktree"
    fi
  fi

  debug "push target: '$target' ($label)"

  local files
  files="$(resolve_files "$REPO_ROOT")"

  if [ -z "$files" ]; then
    echo "No .env files matched in this worktree."
    exit 1
  fi

  echo "Push to $label ($target):"
  local found=()
  while IFS= read -r rel; do
    echo "  $rel"
    found+=("$rel")
  done <<< "$files"
  echo ""

  local has_diff=false
  for rel in "${found[@]}"; do
    dest="${target}/${rel}"
    if [ -f "$dest" ] && ! diff -q "${REPO_ROOT}/${rel}" "$dest" > /dev/null 2>&1; then
      has_diff=true
      break
    fi
  done

  if [ "$has_diff" = true ]; then
    echo "Warning: this will overwrite files in $label."
    printf "Continue? [y/N] "
    read -r answer
    if [[ ! "$answer" =~ ^[Yy]$ ]]; then
      echo "Aborted."
      exit 0
    fi
  fi

  local count=0
  for rel in "${found[@]}"; do
    src="${REPO_ROOT}/${rel}"
    dest="${target}/${rel}"
    mkdir -p "$(dirname "$dest")"
    debug "cp $src -> $dest"
    cp "$src" "$dest"
    echo "  pushed: $rel"
    count=$((count + 1))
  done

  echo "Pushed $count env file(s) to $label"
}

case "${1:-}" in
  init) cmd_init ;;
  pull) cmd_pull "${2:-}" ;;
  push) cmd_push "${2:-}" ;;
  *) usage ;;
esac
